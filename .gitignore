# python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# run artifacts
logs/
viz/
wandb/
outputs/
*.ckpt
*.pth

# dataset blobs only (NOT python `data/` packages or config/data/ — those are code).

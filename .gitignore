# python (junk anywhere)
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.ipynb_checkpoints/

# build artifacts (rebuilt per env; sources are kept)
build/
dist/
*.so
*.o

# run outputs — REPO ROOT ONLY (anchored, so vendored code dirs of these names are kept)
/logs/
/viz/
/wandb/
/outputs/

# vendored repos' own run artifacts (their example logs etc.)
third_party/**/logs/
third_party/**/wandb/
third_party/**/outputs/

# NOTE: do NOT add a bare `data/` — it would drop config/data/ and the python
# */data/ subpackages. The nuScenes dataset lives outside the repo (absolute path).

# local tmux launch helpers (server-specific abs paths)
/run_*.sh
